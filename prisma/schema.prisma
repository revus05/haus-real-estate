generator client {
  provider     = "prisma-client"
  output       = "../lib/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  REALTOR
  ADMIN
}

enum DealType {
  SALE
  RENT
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  COMMERCIAL
  LAND
  TOWNHOUSE
}

enum ModerationStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  DONE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  phone        String?
  avatarUrl    String?
  role         Role       @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  properties   Property[]
  leads        Lead[]     @relation("LeadRealtor")

  @@map("users")
}

model Property {
  id               String           @id @default(cuid())
  title            String
  description      String
  dealType         DealType
  propertyType     PropertyType
  price            Decimal          @db.Decimal(12, 2)
  currency         String           @default("USD")
  rooms            Int?
  area             Decimal?         @db.Decimal(8, 2)
  floor            Int?
  totalFloors      Int?
  address          String
  city             String
  district         String?
  latitude         Decimal?         @db.Decimal(9, 6)
  longitude        Decimal?         @db.Decimal(9, 6)
  images           PropertyImage[]
  moderationStatus ModerationStatus @default(PENDING)
  viewCount        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  ownerId          String
  owner            User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  leads            Lead[]

  @@index([city])
  @@index([dealType])
  @@index([propertyType])
  @@index([moderationStatus])
  @@index([ownerId])
  @@map("properties")
}

model PropertyImage {
  id           String   @id @default(cuid())
  url          String
  cloudinaryId String
  altText      String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model Lead {
  id         String     @id @default(cuid())
  name       String
  contact    String
  message    String?
  status     LeadStatus @default(NEW)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  propertyId String
  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  realtorId  String
  realtor    User       @relation("LeadRealtor", fields: [realtorId], references: [id])

  @@index([realtorId])
  @@index([propertyId])
  @@map("leads")
}
